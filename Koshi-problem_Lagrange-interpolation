def simpson (func, a, b, n):
    h = (b - a) / n
    
    x = [a + i * h for i in range (1,n)]
    #s1 - сумма элементов с четными индексами
    #s2 - сумма элементов с нечетными индексами
    s1 = sum(func(element) for element in x[1::2])
    s2 = sum(func(element) for element in x[::2])
    
    return h/3 * (func(a) + 2 * s1 + 4 * s2 + func(b))


