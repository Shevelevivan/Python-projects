# In[3]:


def divided_difference(x, y):
    n = len(y)
    coef = np.zeros((n, n))
    coef[:, 0] = y

    for j in range(1, n):
        for i in range(n - j):
            coef[i][j] = (coef[i + 1][j - 1] - coef[i][j - 1]) / (x[i + j] - x[i])
    
    return coef[0]


# In[4]:


def newton_interpolation(x, y):
    n = len(x)
    coef = divided_difference(x, y)

    def polynomial(X):
        result = 0
        for i in range(n):
            term = coef[i]
            for j in range(i):
                term *= (X - x[j])
            result += term
        return result

    return polynomial


