def bisection_method(func, a, b, tol=1e-6, max_iter=5000):
    if func(a) * func(b) >= 0:
        raise ValueError("f(a) and f(b) must have different signs")
    elif round(func(a),6) == 0.0: return a
    elif round(func(b),6) == 0.0: return b
    
    for _ in range(max_iter):
        c = (a + b) / 2
        if abs(func(c)) <= tol:
            return c
        elif func(a) * func(c) <= 0.0:
            b = c
        else:
            a = c
    return (a + b) / 2


